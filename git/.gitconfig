[user]
	name = Namit Deb
	email = namitdeb739@gmail.com

[core]
	editor = code --wait
	pager = delta
	excludesfile = ~/.gitignore_global
	autocrlf = input

[init]
	defaultBranch = main

[push]
	default = current
	autoSetupRemote = true

[pull]
	rebase = true

[fetch]
	prune = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[rebase]
	autoStash = true

[alias]
	# Shorthands with no shell alias equivalent
	cm = commit -m
	ca = commit --amend
	cp = cherry-pick
	ll = log --pretty=format:'%C(yellow)%h%Creset %s %C(green)(%cr)%Creset %C(blue)<%an>%Creset' -20
	undo = reset --soft HEAD~1
	unstage = restore --staged
	wip = !git add -A && git commit -m 'chore: wip'
	cleanup = !git branch --merged main | grep -v 'main' | xargs -r git branch -d

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
